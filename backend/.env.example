APP_NAME="Sensory Composer"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://your-laravel-service.onrender.com

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=secret
DB_SSLMODE=require

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync

FASTAPI_URL=https://your-fastapi-service.onrender.com
RUST_DSP_URL=https://your-rust-dsp-service.onrender.com

COUCHDB_URL=https://your-couchdb.onrender.com
COUCHDB_DB=sensory-composer-scores

FRONTEND_URL=https://your-project.vercel.app